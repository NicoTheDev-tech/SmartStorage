@model IEnumerable<SmartStorage.Core.Entities.Contract>
@{
    ViewData["Title"] = "Manage Contracts";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Manage Contracts</h1>
            <p class="text-muted">View and manage all storage contracts</p>
        </div>
        <div>
            <a href="/Admin/Contracts/Create" class="btn btn-gold">
                <i class="bi bi-plus-circle"></i> Create Contract
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Contract #</th>
                            <th>Client</th>
                            <th>Unit</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Monthly Rate</th>
                            <th>Total Value</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contract in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@contract.ContractNumber</td>
                                <td>@contract.Booking?.Client?.FullName</td>
                                <td>@contract.Booking?.StorageUnit?.UnitNumber</td>
                                <td>@contract.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@contract.EndDate.ToString("dd MMM yyyy")</td>
                                <td class="text-gold">R @contract.MonthlyRate.ToString("N0")</td>
                                <td>R @contract.TotalContractValue.ToString("N0")</td>
                                <td>
                                    @{
                                        var statusClass = contract.Status.ToString() switch
                                        {
                                            "Active" => "success",
                                            "Accepted" => "info",
                                            "PendingAcceptance" => "warning",
                                            "Expired" => "secondary",
                                            "Terminated" => "danger",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@statusClass">@contract.Status</span>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="/Admin/Contracts/Details/@contract.Id" class="btn btn-sm btn-outline-gold">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (contract.Status.ToString() == "PendingAcceptance")
                                        {
                                            <form asp-action="ApproveContract" asp-route-id="@contract.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success ms-1">Approve</button>
                                            </form>
                                        }
                                        @if (contract.Status.ToString() == "Accepted")
                                        {
                                            <form asp-action="ActivateContract" asp-route-id="@contract.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-primary ms-1">Activate</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5">
                                    <i class="bi bi-file-text fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No contracts found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .btn-gold {
        background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
        color: #2c2c2c;
        font-weight: 600;
        border: none;
    }
    .btn-gold:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(212,175,55,0.3);
        color: #2c2c2c;
    }
</style>