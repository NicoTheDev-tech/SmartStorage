@model IEnumerable<SmartStorage.Core.Entities.DeliverySchedule>
@{
    ViewData["Title"] = "Delivery & Logistics";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Delivery & Logistics</h1>
            <p class="text-muted">Manage all delivery schedules and logistics</p>
        </div>
        <div>
            <a href="/Admin/Delivery/Calendar" class="btn btn-outline-gold">
                <i class="bi bi-calendar"></i> Calendar View
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Schedule #</th>
                            <th>Client</th>
                            <th>Unit</th>
                            <th>Type</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Items</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var schedule in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@schedule.ScheduleNumber</td>
                                <td>@schedule.Booking?.Client?.FullName</td>
                                <td>@schedule.Booking?.StorageUnit?.UnitNumber</td>
                                <td>@schedule.DeliveryType</td>
                                <td>@schedule.ScheduledDate.ToString("dd MMM yyyy")</td>
                                <td>@schedule.TimeSlot</td>
                                <td>@schedule.ItemCount</td>
                                <td>
                                    @{
                                        var statusClass = schedule.Status.ToString() switch
                                        {
                                            "Pending" => "warning",
                                            "Confirmed" => "info",
                                            "Completed" => "success",
                                            "Cancelled" => "danger",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@statusClass">@schedule.Status</span>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a href="/Admin/Delivery/Details/@schedule.Id" class="btn btn-sm btn-outline-gold">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (schedule.Status.ToString() == "Pending")
                                        {
                                            <form asp-action="ConfirmDelivery" asp-route-id="@schedule.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success ms-1">Confirm</button>
                                            </form>
                                        }
                                        @if (schedule.Status.ToString() == "Confirmed")
                                        {
                                            <form asp-action="CompleteDelivery" asp-route-id="@schedule.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-primary ms-1">Complete</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5">
                                    <i class="bi bi-truck fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No delivery schedules found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .btn-outline-gold {
        border: 2px solid #D4AF37;
        color: #D4AF37;
        background: transparent;
        font-weight: 600;
    }
    .btn-outline-gold:hover {
        background: #D4AF37;
        color: #2c2c2c;
    }
</style>