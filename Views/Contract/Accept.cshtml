@model SmartStorage.Core.DTOs.ContractResponseDto
@{
    ViewData["Title"] = "Accept Contract - " + Model.ContractNumber;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg">
                <div class="card-header text-center py-4" style="background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);">
                    <i class="bi bi-file-check fs-1 text-white"></i>
                    <h3 class="text-white mb-0">Accept Storage Contract</h3>
                    <p class="text-white-50 mb-0">@Model.ContractNumber</p>
                </div>
                <div class="card-body p-5">
                    <div class="alert alert-info mb-4">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Please review the contract terms carefully before accepting.
                    </div>

                    <div class="mb-4">
                        <h5><i class="bi bi-box text-gold"></i> Storage Details</h5>
                        <div class="row g-3 mt-2">
                            <div class="col-md-6">
                                <div class="border p-3 rounded-3">
                                    <small class="text-muted">Unit Number</small>
                                    <h5 class="mb-0">@Model.UnitNumber</h5>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="border p-3 rounded-3">
                                    <small class="text-muted">Unit Size</small>
                                    <h5 class="mb-0">@Model.UnitSize</h5>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5><i class="bi bi-calculator text-gold"></i> Financial Summary</h5>
                        <div class="border rounded-3 mt-2">
                            <div class="d-flex justify-content-between p-3 border-bottom">
                                <span>Monthly Rate</span>
                                <strong>R @Model.MonthlyRate.ToString("N0")</strong>
                            </div>
                            <div class="d-flex justify-content-between p-3 border-bottom">
                                <span>Security Deposit</span>
                                <strong>R @Model.SecurityDeposit.ToString("N0")</strong>
                            </div>
                            <div class="d-flex justify-content-between p-3 bg-light">
                                <span>Total Contract Value</span>
                                <strong class="text-gold">R @Model.TotalContractValue.ToString("N0")</strong>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <h5><i class="bi bi-file-text text-gold"></i> Terms & Conditions</h5>
                        <div class="border rounded-3 p-3 bg-light" style="max-height: 300px; overflow-y: auto;">
                            <pre style="white-space: pre-wrap; font-family: inherit; font-size: 0.85rem;">@Model.TermsAndConditions</pre>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.SpecialConditions))
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-star-fill me-2"></i>
                            <strong>Special Conditions:</strong> @Model.SpecialConditions
                        </div>
                    }

                    <form asp-action="Accept" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" name="ContractId" value="@Model.Id" />
                        
                        <div class="form-check mb-4">
                            <input class="form-check-input" type="checkbox" id="agreeToTerms" name="AgreeToTerms" value="true" required>
                            <label class="form-check-label" for="agreeToTerms">
                                I confirm that I have read, understood, and agree to all the terms and conditions of this storage contract.
                            </label>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Digital Signature (Full Name)</label>
                            <input type="text" class="form-control" name="AcceptedBy" placeholder="Enter your full name to digitally sign" required>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-gold btn-lg">
                                <i class="bi bi-check2-circle"></i> I Accept the Contract Terms
                            </button>
                            <a href="/Contracts/View/@Model.Id" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Review Contract Again
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
</style>