@model IEnumerable<SmartStorage.Core.DTOs.InvoiceDto>
@{
    ViewData["Title"] = "My Invoices";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">My Invoices</h1>
        <div class="gold-line mx-auto"></div>
        <p class="text-muted mt-3">View and pay your invoices</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Invoice #</th>
                                <th>Date</th>
                                <th>Due Date</th>
                                <th>Amount</th>
                                <th>Paid</th>
                                <th>Balance</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var invoice in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@invoice.InvoiceNumber</td>
                                    <td>@invoice.InvoiceDate.ToString("dd MMM yyyy")</td>
                                    <td>@invoice.DueDate.ToString("dd MMM yyyy")</td>
                                    <td class="text-gold fw-bold">R @invoice.Amount.ToString("N2")</td>
                                    <td>R @invoice.AmountPaid.ToString("N2")</td>
                                    <td>R @invoice.Balance.ToString("N2")</td>
                                    <td>
                                        @if (invoice.Status == "Paid")
                                        {
                                            <span class="badge bg-success">Paid</span>
                                        }
                                        else if (invoice.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@invoice.Status</span>
                                        }
                                    </td>
                                    <td>
                                        @if (invoice.Status != "Paid")
                                        {
                                            <a href="/Invoices/Pay/@invoice.Id" class="btn btn-sm btn-gold">Pay Now</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Paid</span>
                                        }
                                    </td>

                                    <td class="text-center">
    <a href="/Invoices/View/@invoice.Id" class="btn btn-sm btn-outline-gold">
        <i class="bi bi-eye"></i> View
    </a>
</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-receipt fs-1 text-muted"></i>
            <h4 class="text-muted mt-3">No Invoices Found</h4>
            <p class="text-muted">You don't have any invoices yet.</p>
        </div>
    }
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .btn-gold {
        background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
        color: #2c2c2c;
        font-weight: 600;
        border: none;
        border-radius: 50px;
        padding: 5px 15px;
    }
</style>