@model IEnumerable<SmartStorage.Core.DTOs.InvoiceDto>
@{
    ViewData["Title"] = "Payment History";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Payment History</h1>
        <div class="gold-line mx-auto"></div>
        <p class="text-muted mt-3">Complete payment history</p>
    </div>

    @if (Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Invoice #</th>
                                <th>Payment Date</th>
                                <th>Amount</th>
                                <th>Method</th>
                                <th>Reference</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var payment in Model.Where(p => p.Status == "Paid"))
                            {
                                <tr>
                                    <td class="fw-semibold">@payment.InvoiceNumber</td>
                                    <td>@payment.PaymentDate?.ToString("dd MMM yyyy")</td>
                                    <td>R @payment.AmountPaid.ToString("N2")</td>
                                    <td>@payment.PaymentMethod</td>
                                    <td>@payment.PaymentReference</td>
                                    <td>
                                        <a href="/Invoices/Details/@payment.Id" class="btn btn-sm btn-outline-gold">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-clock-history fs-1 text-muted"></i>
            <h4 class="text-muted mt-3">No Payment History</h4>
            <p class="text-muted">You haven't made any payments yet.</p>
        </div>
    }
</div>