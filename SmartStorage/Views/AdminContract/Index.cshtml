@model IEnumerable<SmartStorage.Core.DTOs.ContractResponseDto>
@{
    ViewData["Title"] = "Contract Management";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Contract Management</h1>
            <p class="text-muted">Manage all storage contracts</p>
        </div>
        <div>
            <a href="/Admin/Bookings/Pending" class="btn btn-outline-gold">
                <i class="bi bi-file-text"></i> Create from Booking
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Contract #</th>
                            <th>Client</th>
                            <th>Unit</th>
                            <th>Duration</th>
                            <th>Total Value</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contract in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@contract.ContractNumber</td>
                                <td>@contract.ClientName</td>
                                <td>@contract.UnitNumber</td>
                                <td>@contract.DurationMonths months</td>
                                <td>R @contract.TotalContractValue.ToString("N0")</td>
                                <td>
                                    @{
                                        var statusClass = contract.Status switch
                                        {
                                            "Active" => "success",
                                            "Accepted" => "info",
                                            "PendingAcceptance" => "warning",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@statusClass">@contract.Status</span>
                                </td>
                                <td>@contract.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a href="/Admin/Contracts/Details/@contract.Id" class="btn btn-sm btn-outline-gold">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <i class="bi bi-file-text fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No contracts found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);
    </script>
}