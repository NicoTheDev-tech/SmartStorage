@model SmartStorage.Core.DTOs.ContractResponseDto
@{
    ViewData["Title"] = "Contract Details - " + Model.ContractNumber;
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <!-- Contract Header -->
            <div class="card border-0 shadow-lg mb-4 overflow-hidden">
                <div class="card-header bg-gradient" style="background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h3 class="text-white mb-0">📄 @Model.ContractNumber</h3>
                            <p class="text-white-50 mb-0">Storage Contract</p>
                        </div>
                        <div>
                            @{
                                var statusClass = Model.Status switch
                                {
                                    "Active" => "success",
                                    "Accepted" => "info",
                                    "PendingAcceptance" => "warning",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge bg-@statusClass fs-6 px-3 py-2">@Model.Status</span>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <!-- Contract Details -->
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="info-card p-3 bg-light rounded-3">
                                <h6 class="text-gold mb-3"><i class="bi bi-person"></i> Client Information</h6>
                                <p class="mb-1"><strong>Name:</strong> @Model.ClientName</p>
                                <p class="mb-0"><strong>Email:</strong> @Model.ClientEmail</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-card p-3 bg-light rounded-3">
                                <h6 class="text-gold mb-3"><i class="bi bi-box"></i> Storage Unit</h6>
                                <p class="mb-1"><strong>Unit:</strong> @Model.UnitNumber</p>
                                <p class="mb-0"><strong>Size:</strong> @Model.UnitSize</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-card p-3 bg-light rounded-3">
                                <h6 class="text-gold mb-3"><i class="bi bi-calendar"></i> Contract Period</h6>
                                <p class="mb-1"><strong>Start:</strong> @Model.StartDate.ToString("dd MMMM yyyy")</p>
                                <p class="mb-1"><strong>End:</strong> @Model.EndDate.ToString("dd MMMM yyyy")</p>
                                <p class="mb-0"><strong>Duration:</strong> @Model.DurationMonths months</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-card p-3 bg-light rounded-3">
                                <h6 class="text-gold mb-3"><i class="bi bi-calculator"></i> Financial Summary</h6>
                                <p class="mb-1"><strong>Monthly Rate:</strong> R @Model.MonthlyRate.ToString("N0")</p>
                                <p class="mb-1"><strong>Security Deposit:</strong> R @Model.SecurityDeposit.ToString("N0")</p>
                                <p class="mb-0"><strong>Total Contract Value:</strong> R @Model.TotalContractValue.ToString("N0")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Terms and Conditions -->
                    <div class="mt-4">
                        <div class="card border-0 bg-light">
                            <div class="card-header bg-transparent border-0 pt-3">
                                <h5 class="mb-0 text-gold"><i class="bi bi-file-text"></i> Terms & Conditions</h5>
                            </div>
                            <div class="card-body pt-0">
                                <div class="terms-container" style="max-height: 300px; overflow-y: auto;">
                                    <pre style="white-space: pre-wrap; font-family: inherit; font-size: 0.9rem;">@Model.TermsAndConditions</pre>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.SpecialConditions))
                    {
                        <div class="mt-3">
                            <div class="alert alert-warning">
                                <i class="bi bi-star-fill me-2"></i>
                                <strong>Special Conditions:</strong> @Model.SpecialConditions
                            </div>
                        </div>
                    }

                    <!-- Dates -->
                    <div class="mt-4 pt-3 border-top">
                        <div class="row text-muted small">
                            <div class="col-md-4">
                                <i class="bi bi-calendar-plus"></i> Created: @Model.CreatedAt.ToString("dd MMM yyyy HH:mm")
                            </div>
                            @if (Model.AcceptedAt.HasValue)
                            {
                                <div class="col-md-4">
                                    <i class="bi bi-check-circle"></i> Accepted: @Model.AcceptedAt.Value.ToString("dd MMM yyyy HH:mm")
                                </div>
                            }
                            @if (Model.ActivatedAt.HasValue)
                            {
                                <div class="col-md-4">
                                    <i class="bi bi-play-circle"></i> Activated: @Model.ActivatedAt.Value.ToString("dd MMM yyyy HH:mm")
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 pb-4">
                    @if (Model.CanActivate && User.IsInRole("Admin"))
                    {
                        <form asp-action="Activate" asp-route-id="@Model.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-gold" onclick="return confirm('Activate this contract? This will start the storage period.')">
                                <i class="bi bi-play-fill"></i> Activate Contract
                            </button>
                        </form>
                    }
                    <a href="/Admin/Contracts" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .info-card {
        transition: transform 0.2s;
    }
    .info-card:hover {
        transform: translateY(-2px);
    }
    .terms-container pre {
        white-space: pre-wrap;
        font-family: inherit;
        font-size: 0.9rem;
        line-height: 1.6;
    }
</style>