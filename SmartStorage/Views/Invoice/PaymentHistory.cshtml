@using SmartStorage.Core.Entities
@model IEnumerable<SmartStorage.Core.Entities.Payment>

@{
    ViewData["Title"] = "Payment History";
}

<div class="container py-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0"><i class="bi bi-credit-card me-2"></i>Payment History</h3>
            <p class="mb-0 text-white-50">Complete payment history</p>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice #</th>
                            <th>Payment Date</th>
                            <th class="text-end">Amount</th>
                            <th>Method</th>
                            <th>Reference</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var payment in Model)
                            {
                                <tr>
                                    <td>
                                        <a href="@Url.Action("Details", "Invoice", new { id = payment.BookingId })" class="text-decoration-none">
                                            INV-@payment.BookingId
                                        </a>
                                    </td>
                                    <td>@payment.PaymentDate.ToString("dd MMM yyyy")</td>
                                    <td class="text-end">R @payment.Amount.ToString("N2")</td>
                                    <td>@payment.Method</td>
                                    <td>@payment.TransactionId</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No payment history found.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>