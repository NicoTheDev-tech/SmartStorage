@model IEnumerable<SmartStorage.Core.Entities.Payment>
@{
    ViewData["Title"] = "Billing & Payments";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Billing & Payments</h1>
            <p class="text-muted">Manage all customer payments and invoices</p>
        </div>
        <div class="d-flex gap-2">
            <div class="card bg-gold-light p-2 px-3">
                <small class="text-muted">Total Revenue</small>
                <strong class="text-gold fs-5">R @Model.Where(p => p.Status.ToString() == "Completed").Sum(p => p.Amount).ToString("N0")</strong>
            </div>
            <div class="card bg-warning-light p-2 px-3">
                <small class="text-muted">Pending</small>
                <strong class="text-warning fs-5">R @Model.Where(p => p.Status.ToString() == "Pending").Sum(p => p.Amount).ToString("N0")</strong>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Payment #</th>
                            <th>Client</th>
                            <th>Booking #</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@payment.PaymentReference</td>
                                <td>@payment.Booking?.Client?.FullName</td>
                                <td>@payment.Booking?.BookingNumber</td>
                                <td class="text-gold">R @payment.Amount.ToString("N0")</td>
                                <td>@payment.PaymentDate.ToString("dd MMM yyyy")</td>
                                <td>@payment.Method</td>
                                <td>
                                    @{
                                        var statusClass = payment.Status.ToString() == "Completed" ? "success" : "warning";
                                    }
                                    <span class="badge bg-@statusClass">@payment.Status</span>
                                </td>
                                <td>
                                    @if (payment.Status.ToString() == "Pending")
                                    {
                                        <form asp-action="VerifyPayment" asp-route-id="@payment.Id" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success">Verify</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Verified</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <i class="bi bi-receipt fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No payments found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .bg-gold-light {
        background: rgba(212, 175, 55, 0.1);
    }
    .bg-warning-light {
        background: rgba(255, 193, 7, 0.1);
    }
</style>