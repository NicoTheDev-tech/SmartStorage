@model IEnumerable<SmartStorage.Core.Entities.StorageUnit>
@{
    ViewData["Title"] = "Storage Units Management";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Storage Units</h1>
            <p class="text-muted">Manage all storage units in the system</p>
        </div>
        <div>
            <a href="/Admin/StorageUnits/Create" class="btn btn-gold">
                <i class="bi bi-plus-circle"></i> Add New Unit
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Unit #</th>
                            <th>Size</th>
                            <th>Monthly Rate</th>
                            <th>Location</th>
                            <th>Climate Control</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@unit.UnitNumber</td>
                                <td>@unit.Size</td>
                                <td class="text-gold fw-bold">R @unit.MonthlyRate.ToString("N0")</td>
                                <td>@unit.Location</td>
                                <td>@unit.ClimateControl</td>
                                <td>
                                    <span class="badge bg-@(unit.IsActive ? "success" : "danger")">
                                        @(unit.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>
                                    <a href="/Admin/StorageUnits/Edit/@unit.Id" class="btn btn-sm btn-outline-gold">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form asp-action="DeleteUnit" asp-route-id="@unit.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this unit?')">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
</style>