@using SmartStorage.Core.Entities
@model IEnumerable<SmartStorage.Core.Entities.StorageUnit>

@{
    ViewData["Title"] = "Storage Units";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Storage Units</h1>
            <p class="text-muted">Manage all storage units in the system</p>
        </div>
        <a href="/Admin/StorageUnits/Create" class="btn btn-gold">
            <i class="bi bi-plus-circle"></i> Add New Unit
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Unit #</th>
                            <th>Size</th>
                            <th>Monthly Rate</th>
                            <th>Location</th>
                            <th>Climate Control</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in Model)
                        {
                            <tr>
                                <td>@unit.UnitNumber</td>
                                <td>@unit.Size</td>
                                <td>R @unit.MonthlyRate.ToString("N2")</td>
                                <td>@(unit.Location ?? "N/A")</td>
                                <td>@(unit.ClimateControl ?? "None")</td>
                                <td>
                                    @if (unit.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a href="/Admin/StorageUnits/Edit/@unit.Id" class="btn btn-sm btn-primary">Edit</a>
                                    <form asp-action="DeleteUnit" asp-route-id="@unit.Id" method="post" style="display:inline-block">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this unit?')">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-gold {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        color: var(--charcoal);
        font-weight: 600;
        border: none;
    }
    .btn-gold:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(212,175,55,0.3);
        color: var(--charcoal);
    }
</style>