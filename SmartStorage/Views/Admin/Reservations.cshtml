@using SmartStorage.Core.Entities
@model IEnumerable<SmartStorage.Core.Entities.Booking>

@{
    ViewData["Title"] = "Reservations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Reservations</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Booking #</th>
                            <th>Client</th>
                            <th>Unit</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td>@booking.BookingNumber</td>
                                <td>@(booking.Client?.FullName ?? "Unknown")</td>
                                <td>@(booking.StorageUnit?.UnitNumber ?? "Unknown")</td>
                                <td>@booking.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@booking.EndDate.ToString("dd MMM yyyy")</td>
                                <td>R @booking.TotalAmount.ToString("N2")</td>
                                <td>
                                    @if (booking.Status == BookingStatus.Confirmed)
                                    {
                                        <span class="badge bg-success">Confirmed</span>
                                    }
                                    else if (booking.Status == BookingStatus.Pending)
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                    else if (booking.Status == BookingStatus.Cancelled)
                                    {
                                        <span class="badge bg-secondary">Cancelled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">@booking.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (booking.Status == BookingStatus.Pending)
                                    {
                                        <form asp-action="UpdateBookingStatus" asp-route-id="@booking.Id" asp-route-status="Confirmed" method="post" style="display:inline-block">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                        </form>
                                    }
                                    
                                    @if (booking.Status != BookingStatus.Cancelled)
                                    {
                                        <form asp-action="UpdateBookingStatus" asp-route-id="@booking.Id" asp-route-status="Cancelled" method="post" style="display:inline-block">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div> 