@{
    ViewData["Title"] = "Reports & Analytics";
    var totalRevenue = ViewBag.TotalRevenue ?? 0m;
    var monthlyRevenue = ViewBag.MonthlyRevenue ?? 0m;
    var totalBookings = ViewBag.TotalBookings ?? 0;
    var activeContracts = ViewBag.ActiveContracts ?? 0;
    var totalUsers = ViewBag.TotalUsers ?? 0;
    var availableUnits = ViewBag.AvailableUnits ?? 0;
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="display-5 fw-bold">Reports & Analytics</h1>
        <p class="text-muted">View business insights and performance metrics</p>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-currency-dollar fs-2 text-gold"></i>
                    <h3 class="mt-2 mb-0">R @totalRevenue.ToString("N0")</h3>
                    <p class="text-muted mb-0">Total Revenue</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-graph-up fs-2 text-gold"></i>
                    <h3 class="mt-2 mb-0">R @monthlyRevenue.ToString("N0")</h3>
                    <p class="text-muted mb-0">Monthly Revenue</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-journal-bookmark-fill fs-2 text-gold"></i>
                    <h3 class="mt-2 mb-0">@totalBookings</h3>
                    <p class="text-muted mb-0">Total Bookings</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-file-text fs-2 text-gold"></i>
                    <h3 class="mt-2 mb-0">@activeContracts</h3>
                    <p class="text-muted mb-0">Active Contracts</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-people fs-2 text-gold"></i>
                    <h3 class="mt-2 mb-0">@totalUsers</h3>
                    <p class="text-muted mb-0">Total Users</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-box-seam fs-2 text-gold"></i>
                    <h3 class="mt-2 mb-0">@availableUnits</h3>
                    <p class="text-muted mb-0">Available Units</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-credit-card fs-2 text-gold"></i>
                    <h3 class="mt-2 mb-0">Payment Summary</h3>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Completed Payments</span>
                            <strong class="text-success">R @ViewBag.CompletedPayments?.ToString("N0") ?? "0"</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Pending Payments</span>
                            <strong class="text-warning">R @ViewBag.PendingPayments?.ToString("N0") ?? "0"</strong>
                        </div>
                        <div class="progress mt-2">
                            @{
                                var completedPercent = (ViewBag.CompletedPayments + ViewBag.PendingPayments) > 0 
                                    ? (ViewBag.CompletedPayments / (ViewBag.CompletedPayments + ViewBag.PendingPayments) * 100) 
                                    : 0;
                            }
                            <div class="progress-bar bg-gold" style="width: @completedPercent%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-truck fs-2 text-gold"></i>
                    <h3 class="mt-2 mb-0">Delivery Status</h3>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Pending Deliveries</span>
                            <strong class="text-warning">@ViewBag.PendingDeliveries?.ToString() ?? "0"</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Completed Deliveries</span>
                            <strong class="text-success">@ViewBag.CompletedDeliveries?.ToString() ?? "0"</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Confirmed Deliveries</span>
                            <strong class="text-info">@ViewBag.ConfirmedDeliveries?.ToString() ?? "0"</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Export Button -->
    <div class="text-end mt-4">
        <button class="btn btn-gold" onclick="window.print()">
            <i class="bi bi-printer"></i> Export Report
        </button>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .bg-gold {
        background-color: var(--gold);
    }
    .progress-bar {
        background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
    }
    .btn-gold {
        background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
        color: #2c2c2c;
        font-weight: 600;
        border: none;
    }
    .btn-gold:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(212,175,55,0.3);
    }
</style>