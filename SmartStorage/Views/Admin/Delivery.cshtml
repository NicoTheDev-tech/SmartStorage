@model IEnumerable<SmartStorage.Core.DTOs.DeliveryScheduleResponseDto>
@{
    ViewData["Title"] = "Delivery & Logistics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Delivery & Logistics</h1>
            <p class="text-muted">Manage all delivery schedules and logistics</p>
        </div>
        <a href="/Admin/Delivery/Calendar" class="btn btn-outline-gold">
            <i class="bi bi-calendar"></i> Calendar View
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Schedule #</th>
                            <th>Client</th>
                            <th>Unit</th>
                            <th>Type</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Items</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var schedule in Model)
                            {
                                <tr>
                                    <td>@schedule.ScheduleNumber</td>
                                    <td>@schedule.ClientName</td>
                                    <td>@schedule.UnitNumber</td>
                                    <td>@schedule.DeliveryType</td>
                                    <td>@schedule.ScheduledDate.ToString("dd MMM yyyy")</td>
                                    <td>@schedule.TimeSlot</td>
                                    <td>@schedule.ItemCount</td>
                                    <td>
                                        @if (schedule.Status == "Completed")
                                        {
                                            <span class="badge bg-success">Completed</span>
                                        }
                                        else if (schedule.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger">Cancelled</span>
                                        }
                                        else if (schedule.Status == "Confirmed")
                                        {
                                            <span class="badge bg-info">Confirmed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="/Admin/Delivery/Details/@schedule.Id" class="btn btn-sm btn-primary">View</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center py-5">
                                    <i class="bi bi-truck fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No delivery schedules found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-outline-gold {
        border: 2px solid #D4AF37;
        color: #D4AF37;
        background: transparent;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-outline-gold:hover {
        background: #D4AF37;
        color: #2c2c2c;
        transform: translateY(-2px);
    }
</style>