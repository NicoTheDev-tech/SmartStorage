@{
    var booking = ViewBag.Booking as SmartStorage.Core.DTOs.BookingResponseDto;
    var terms = ViewBag.Terms as string ?? "";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header text-center py-4" style="background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);">
                    <i class="bi bi-file-text fs-1 text-white"></i>
                    <h3 class="text-white mb-0 mt-2">Storage Contract</h3>
                    <p class="text-white-50">Please review before signing</p>
                </div>
                <div class="card-body p-4">
                    <h5>Booking #@booking?.BookingNumber</h5>
                    <p><strong>Unit:</strong> @booking?.UnitNumber</p>
                    <p><strong>Period:</strong> @booking?.StartDate.ToString("dd MMM yyyy") - @booking?.EndDate.ToString("dd MMM yyyy")</p>
                    <p><strong>Total Amount:</strong> R @booking?.TotalAmount</p>
                    
                    <div class="mb-4">
                        <h5>Terms and Conditions</h5>
                        <div class="border p-3 bg-light rounded" style="max-height: 400px; overflow-y: auto;">
                            <pre style="white-space: pre-wrap; font-family: inherit; font-size: 0.9rem;">@terms</pre>
                        </div>
                    </div>
                    
                    <form method="post" action="/Contracts/Create">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookingId" value="@booking?.Id" />
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="acceptTerms" name="acceptTerms" value="true" required>
                            <label class="form-check-label" for="acceptTerms">
                                I have read, understood, and agree to the Terms and Conditions
                            </label>
                        </div>
                        <button type="submit" class="btn btn-gold w-100">Sign Contract</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-gold {
        background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
        color: #2c2c2c;
        font-weight: 600;
        border: none;
        border-radius: 50px;
        padding: 12px;
    }
</style>