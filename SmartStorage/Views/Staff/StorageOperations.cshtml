@using SmartStorage.Core.Entities
@model IEnumerable<SmartStorage.Core.Entities.Booking>

@{
    ViewData["Title"] = "Storage Operations";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-5 fw-bold">Storage Operations</h1>
            <p class="text-muted">Active storage units and their status</p>
        </div>
        <div class="col text-end">
            <span class="badge bg-gold p-2">Today: @DateTime.Now.ToString("dd MMM yyyy")</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-4">
            <h5 class="mb-0"><i class="bi bi-building text-gold"></i> Active Storage Units</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Booking #</th>
                                <th>Client</th>
                                <th>Unit</th>
                                <th>Size</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Monthly Rate</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in Model)
                            {
                                <tr>
                                    <td>@booking.BookingNumber</td>
                                    <td>@(booking.Client?.FullName ?? "Unknown")</td>
                                    <td>@(booking.StorageUnit?.UnitNumber ?? "Unknown")</td>
                                    <td>@(booking.StorageUnit?.Size ?? "Unknown")</td>
                                    <td>@booking.StartDate.ToString("dd MMM yyyy")</td>
                                    <td>@booking.EndDate.ToString("dd MMM yyyy")</td>
                                    <td>R @booking.TotalAmount.ToString("N2")</td>
                                    <td>
                                        @if (booking.Status == BookingStatus.Active)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else if (booking.Status == BookingStatus.Confirmed)
                                        {
                                            <span class="badge bg-info">Confirmed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@booking.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-building fs-1 text-muted"></i>
                    <p class="text-muted mt-2">No active storage units</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .bg-gold {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        color: var(--charcoal);
    }
    .text-gold {
        color: var(--gold);
    }
</style>