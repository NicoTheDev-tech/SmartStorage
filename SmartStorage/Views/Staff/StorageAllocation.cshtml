@model IEnumerable<SmartStorage.Core.Entities.StorageUnit>
@{
    ViewData["Title"] = "Storage Allocation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="display-5 fw-bold">Storage Allocation</h1>
        <p class="text-muted">View available storage units</p>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Unit #</th>
                            <th>Size</th>
                            <th>Monthly Rate</th>
                            <th>Location</th>
                            <th>Climate Control</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var unit in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@unit.UnitNumber</td>
                                    <td>@unit.Size</td>
                                    <td class="text-gold">R @unit.MonthlyRate.ToString("N0")</td>
                                    <td>@unit.Location</td>
                                    <td>@unit.ClimateControl</td>
                                    <td>
                                        <span class="badge bg-@(unit.IsActive ? "success" : "danger")">
                                            @(unit.IsActive ? "Available" : "Occupied")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-box-seam fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No storage units found</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>