@model IEnumerable<SmartStorage.Core.DTOs.DeliveryScheduleResponseDto>
@{
    ViewData["Title"] = "Delivery Handling";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Delivery Handling</h1>
            <p class="text-muted">Manage and assign delivery requests</p>
        </div>
        <div class="text-end">
            <span class="badge bg-gold p-2">
                <i class="bi bi-truck"></i> @Model.Count() Pending
            </span>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-4">
            <h5 class="mb-0"><i class="bi bi-truck text-gold"></i> Delivery Requests</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Schedule #</th>
                            <th>Unit</th>
                            <th>Client</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var schedule in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@schedule.ScheduleNumber</td>
                                    <td>@schedule.UnitNumber</td>
                                    <td>@schedule.BookingNumber</td>
                                    <td>@schedule.ScheduledDate.ToString("dd MMM yyyy")</td>
                                    <td>@schedule.TimeSlot</td>
                                    <td>
                                        @if (schedule.DeliveryType == "Collection")
                                        {
                                            <span class="badge bg-info">Collection</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary">Delivery</span>
                                        }
                                    </td>
                                    <td>
                                        @if (schedule.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else if (schedule.Status == "Confirmed")
                                        {
                                            <span class="badge bg-info">Assigned</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Completed</span>
                                        }
                                    </td>
                                    <td>
                                        @if (schedule.Status == "Pending")
                                        {
                                            <form asp-action="AssignToSelf" asp-route-id="@schedule.Id" method="post" style="display:inline-block">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-gold">
                                                    <i class="bi bi-person-check"></i> Assign to Me
                                                </button>
                                            </form>
                                        }
                                        @if (schedule.Status == "Confirmed")
                                        {
                                            <form asp-action="CompleteDelivery" asp-route-id="@schedule.Id" method="post" style="display:inline-block">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-check-lg"></i> Complete
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <i class="bi bi-truck fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No delivery requests pending</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gold {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        color: var(--charcoal);
    }
    .btn-gold {
        background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
        color: #2c2c2c;
        font-weight: 600;
        border: none;
    }
    .btn-gold:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(212,175,55,0.3);
        color: #2c2c2c;
    }
    .text-gold {
        color: var(--gold);
    }
</style>