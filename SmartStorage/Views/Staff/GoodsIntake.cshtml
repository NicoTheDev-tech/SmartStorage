@model IEnumerable<SmartStorage.Core.Entities.DeliverySchedule>
@{
    ViewData["Title"] = "Goods Intake";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Goods Intake</h1>
            <p class="text-muted">Receive and inspect incoming goods</p>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Schedule #</th>
                            <th>Client</th>
                            <th>Unit</th>
                            <th>Goods Description</th>
                            <th>Items</th>
                            <th>Scheduled Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var schedule in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@schedule.ScheduleNumber</td>
                                    <td>@(schedule.Booking?.Client?.FullName ?? "Unknown")</td>
                                    <td>@(schedule.Booking?.StorageUnit?.UnitNumber ?? "Unknown")</td>
                                    <td>@schedule.GoodsDescription</td>
                                    <td>@schedule.ItemCount</td>
                                    <td>@schedule.ScheduledDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @{
                                            var statusClass = "warning";
                                            if (schedule.Status.ToString() == "InProgress") { statusClass = "info"; }
                                            else if (schedule.Status.ToString() == "Completed") { statusClass = "success"; }
                                        }
                                        <span class="badge bg-@statusClass">@schedule.Status</span>
                                    </td>
                                    <td>
                                        @if (schedule.Status.ToString() == "Pending")
                                        {
                                            <form asp-action="StartIntake" asp-route-id="@schedule.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-primary">Start Intake</button>
                                            </form>
                                        }
                                        else if (schedule.Status.ToString() == "InProgress")
                                        {
                                            <form asp-action="CompleteIntake" asp-route-id="@schedule.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success">Complete & Store</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <i class="bi bi-box-seam fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No pending goods intake</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .btn-outline-gold {
        border: 2px solid #D4AF37;
        color: #D4AF37;
        background: transparent;
        font-weight: 600;
    }
    .btn-outline-gold:hover {
        background: #D4AF37;
        color: #2c2c2c;
        transform: translateY(-2px);
    }
</style>