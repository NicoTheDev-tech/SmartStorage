@model IEnumerable<SmartStorage.Core.DTOs.DeliveryScheduleResponseDto>
@{
    ViewData["Title"] = "Goods Intake";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-5 fw-bold">Goods Intake</h1>
            <p class="text-muted">Process incoming customer goods</p>
        </div>
        <div class="text-end">
            <span class="badge bg-gold p-2">Today: @DateTime.Now.ToString("dd MMM yyyy")</span>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 pt-4">
            <h5 class="mb-0"><i class="bi bi-box-seam text-gold"></i> Pending Intake Requests</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Schedule #</th>
                            <th>Unit</th>
                            <th>Client</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var schedule in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@schedule.ScheduleNumber</td>
                                    <td>@schedule.UnitNumber</td>
                                    <td>@schedule.BookingNumber</td>
                                    <td>@schedule.ScheduledDate.ToString("dd MMM yyyy")</td>
                                    <td>@schedule.ItemCount</td>
                                    <td>
                                        @if (schedule.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else if (schedule.Status == "InProgress")
                                        {
                                            <span class="badge bg-info">In Progress</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Completed</span>
                                        }
                                    </td>
                                    <td>
                                        @if (schedule.Status == "Pending")
                                        {
                                            <form asp-action="StartIntake" asp-route-id="@schedule.Id" method="post" style="display:inline-block">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-primary">Start</button>
                                            </form>
                                        }
                                        @if (schedule.Status == "InProgress")
                                        {
                                            <form asp-action="CompleteIntake" asp-route-id="@schedule.Id" method="post" style="display:inline-block">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success">Complete</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="bi bi-inbox fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No pending intake requests</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-gold {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        color: var(--charcoal);
    }
    .text-gold {
        color: var(--gold);
    }
</style>