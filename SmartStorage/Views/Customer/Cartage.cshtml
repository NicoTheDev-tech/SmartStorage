@model IEnumerable<SmartStorage.Core.DTOs.DeliveryScheduleResponseDto>
@{
    ViewData["Title"] = "Cartage Services";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Cartage Services</h1>
        <div class="gold-line mx-auto"></div>
        <p class="text-muted mt-3">Schedule and manage your deliveries</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var schedule in Model)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body">
                            <h5 class="fw-bold">@schedule.ScheduleNumber</h5>
                            <p class="text-muted">Delivery Type: @schedule.DeliveryType</p>
                            <hr />
                            <p><strong>Date:</strong> @schedule.ScheduledDate.ToString("dd MMM yyyy")</p>
                            <p><strong>Time Slot:</strong> @schedule.TimeSlot</p>
                            <p>
                                <strong>Status:</strong>
                                @if (schedule.Status == "Completed")
                                {
                                    <span class="badge bg-success">Completed</span>
                                }
                                else if (schedule.Status == "Cancelled")
                                {
                                    <span class="badge bg-secondary">Cancelled</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                            </p>
                        </div>
                        <div class="card-footer bg-white border-0 pb-4">
                            <a href="/Customer/DeliveryScheduleDetails/@schedule.Id" class="btn btn-outline-gold">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-truck fs-1 text-muted"></i>
            <h4 class="text-muted mt-3">No Cartage Schedules</h4>
            <p class="text-muted">You haven't scheduled any cartage services yet.</p>
            <a href="/Customer/CreateDeliverySchedule" class="btn btn-gold mt-2">Schedule a Delivery</a>
        </div>
    }
</div>