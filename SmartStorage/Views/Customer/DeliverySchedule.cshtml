@model IEnumerable<SmartStorage.Core.DTOs.DeliveryScheduleResponseDto>
@{
    ViewData["Title"] = "Delivery Schedule";
}

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Delivery Schedule</h1>
        <div class="gold-line mx-auto"></div>
        <p class="text-muted mt-3">Schedule and manage your deliveries</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Schedule New Delivery Button -->
    <div class="mb-4 text-end">
        <a href="/Customer/CreateDeliverySchedule" class="btn btn-gold">
            <i class="bi bi-plus-circle"></i> Schedule New Delivery
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Schedule #</th>
                            <th>Unit</th>
                            <th>Type</th>
                            <th>Date</th>
                            <th>Time</th>
                            <th>Items</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var schedule in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@schedule.ScheduleNumber</td>
                                    <td>@schedule.UnitNumber</td>
                                    <td>@schedule.DeliveryType</td>
                                    <td>@schedule.ScheduledDate.ToString("dd MMM yyyy")</td>
                                    <td>@schedule.TimeSlot</td>
                                    <td>@schedule.ItemCount</td>
                                    <td>
                                        @{
                                            var statusClass = schedule.Status switch
                                            {
                                                "Pending" => "warning",
                                                "Confirmed" => "info",
                                                "Completed" => "success",
                                                "Cancelled" => "danger",
                                                _ => "secondary"
                                            };
                                        }
                                        <span class="badge bg-@statusClass">@schedule.Status</span>
                                    </td>
                                    <td>
                                        <a href="/Customer/DeliveryScheduleDetails/@schedule.Id" class="btn btn-sm btn-outline-gold">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                        @if (schedule.CanReschedule)
                                        {
                                            <a href="/Customer/RescheduleDelivery/@schedule.Id" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-calendar"></i> Reschedule
                                            </a>
                                        }
                                        @if (schedule.CanSchedule)
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="cancelSchedule(@schedule.Id)">
                                                <i class="bi bi-x-circle"></i> Cancel
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5">
                                    <i class="bi bi-truck fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No delivery schedules found</p>
                                    <a href="/Customer/CreateDeliverySchedule" class="btn btn-gold mt-2">
                                        <i class="bi bi-plus-circle"></i> Schedule Your First Delivery
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<form id="cancelForm" asp-action="CancelDeliverySchedule" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="cancelScheduleId" name="id" />
</form>

<script>
    function cancelSchedule(id) {
        if (confirm('Are you sure you want to cancel this delivery schedule?')) {
            document.getElementById('cancelScheduleId').value = id;
            document.getElementById('cancelForm').submit();
        }
    }
</script>

<style>
    .text-gold {
        color: var(--gold);
    }
    .btn-gold {
        background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
        color: #2c2c2c;
        font-weight: 600;
        border: none;
    }
    .btn-gold:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(212,175,55,0.3);
        color: #2c2c2c;
    }
    .btn-outline-gold {
        border: 2px solid #D4AF37;
        color: #D4AF37;
        background: transparent;
        font-weight: 600;
    }
    .btn-outline-gold:hover {
        background: #D4AF37;
        color: #2c2c2c;
    }
</style>