@model IEnumerable<SmartStorage.Core.DTOs.BookingResponseDto>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">My Bookings</h1>
        <div class="gold-line mx-auto"></div>
        <p class="text-muted mt-3">View and manage your storage bookings</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var booking in Model)
            {
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="fw-bold">Booking #@booking.BookingNumber</h5>
                                    <p class="text-muted">Unit @booking.UnitNumber</p>
                                </div>
                                <span class="badge bg-@(booking.Status == "Active" ? "success" : booking.Status == "Confirmed" ? "info" : booking.Status == "Cancelled" ? "danger" : "warning")">
                                    @booking.Status
                                </span>
                            </div>
                            <hr />
                            <p><strong>Dates:</strong> @booking.StartDate.ToString("dd MMM yyyy") - @booking.EndDate.ToString("dd MMM yyyy")</p>
                            <p><strong>Total Amount:</strong> R @booking.TotalAmount.ToString("N2")</p>
                            <p><strong>Paid:</strong> R @booking.AmountPaid.ToString("N2")</p>
                            <p><strong>Balance:</strong> R @booking.Balance.ToString("N2")</p>
                        </div>
                        <div class="card-footer bg-white border-0 pb-4">
                            <a href="/Reserve/Success/@booking.Id" class="btn btn-sm btn-outline-gold">View Details</a>
                            
                            @if (booking.Status == "Pending" || booking.Status == "Confirmed")
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger ms-2" onclick="showCancelModal(@booking.Id, '@booking.BookingNumber', '@booking.UnitNumber')">
                                    <i class="bi bi-x-circle"></i> Cancel Booking
                                </button>
                            }
                            
                            @if (booking.Status == "Cancelled")
                            {
                                <span class="text-muted ms-2">Cancelled</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-bookmark-fill fs-1 text-muted"></i>
            <h4 class="text-muted mt-3">No Bookings Found</h4>
            <p class="text-muted">You haven't made any bookings yet.</p>
            <a href="/Reserve" class="btn btn-gold mt-2">Make a Booking</a>
        </div>
    }
</div>

<!-- Beautiful Custom Cancel Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header" style="background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);">
                <h5 class="modal-title text-white">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Cancel Booking
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="bi bi-question-circle-fill" style="font-size: 4rem; color: #dc3545;"></i>
                <h4 class="mt-3">Are you sure?</h4>
                <p id="cancelMessage" class="text-muted mb-0">You are about to cancel this booking.</p>
                <div class="alert alert-warning mt-3">
                    <i class="bi bi-info-circle me-2"></i>
                    <small>This action cannot be undone. No charges will be applied.</small>
                </div>
            </div>
            <div class="modal-footer justify-content-center border-0 pb-4">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> No, Keep It
                </button>
                <button type="button" class="btn btn-danger px-4" id="confirmCancelBtn">
                    <i class="bi bi-check-circle"></i> Yes, Cancel Booking
                </button>
            </div>
        </div>
    </div>
</div>

<form id="cancelForm" asp-action="CancelBooking" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" id="cancelBookingId" name="bookingId" />
</form>

<script>
    let currentBookingId = 0;
    let currentBookingNumber = '';
    let currentUnitNumber = '';

    function showCancelModal(bookingId, bookingNumber, unitNumber) {
        currentBookingId = bookingId;
        currentBookingNumber = bookingNumber;
        currentUnitNumber = unitNumber;
        
        document.getElementById('cancelMessage').innerHTML = `You are about to cancel booking <strong>${bookingNumber}</strong> for Unit <strong>${unitNumber}</strong>.`;
        
        var myModal = new bootstrap.Modal(document.getElementById('cancelModal'));
        myModal.show();
    }

    document.getElementById('confirmCancelBtn').addEventListener('click', function() {
        document.getElementById('cancelBookingId').value = currentBookingId;
        document.getElementById('cancelForm').submit();
    });
</script>

<style>
    .btn-outline-gold {
        border: 2px solid #D4AF37;
        color: #D4AF37;
        background: transparent;
        font-weight: 600;
        border-radius: 50px;
        padding: 5px 15px;
    }
    .btn-outline-gold:hover {
        background: #D4AF37;
        color: #2c2c2c;
    }
    .btn-outline-danger {
        border-radius: 50px;
        padding: 5px 15px;
    }
    .modal-content {
        border-radius: 20px;
    }
</style>