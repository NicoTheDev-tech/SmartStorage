@using SmartStorage.Core.DTOs
@model SmartStorage.Core.DTOs.CustomerDashboardViewModel

@{
    ViewData["Title"] = "Customer Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);">
                <div class="card-body p-4">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h1 class="mb-2" style="color: #000000;">👋 Welcome back, @Model.ClientPreferredName!</h1>
                            <p class="mb-0" style="color: #000000; opacity: 0.8;">Here's an overview of your SmartStorage account</p>
                        </div>
                        <div class="col-md-4 text-end">
                            <i class="bi bi-house-door" style="font-size: 4rem; color: #000000;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-journal-bookmark-fill fs-1 text-gold"></i>
                    <h3 class="mt-2 mb-0">@Model.ActiveBookings</h3>
                    <p class="text-muted mb-0">Active Bookings</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-file-text fs-1 text-gold"></i>
                    <h3 class="mt-2 mb-0">@Model.ActiveContracts</h3>
                    <p class="text-muted mb-0">Active Contracts</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-receipt fs-1 text-gold"></i>
                    <h3 class="mt-2 mb-0">@Model.TotalInvoices</h3>
                    <p class="text-muted mb-0">Total Invoices</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body text-center">
                    <i class="bi bi-truck fs-1 text-gold"></i>
                    <h3 class="mt-2 mb-0">@Model.UpcomingDeliveries</h3>
                    <p class="text-muted mb-0">Upcoming Deliveries</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-journal-bookmark-fill text-gold"></i> Recent Bookings</h5>
                        <a href="/Customer/MyBookings" class="btn btn-sm btn-outline-gold">View All</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.RecentBookings != null && Model.RecentBookings.Any())
                    {
                        foreach (var booking in Model.RecentBookings)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">Unit @booking.UnitNumber</h6>
                                        <p class="text-muted small mb-0">@booking.StartDate.ToString("dd MMM yyyy") - @booking.EndDate.ToString("dd MMM yyyy")</p>
                                        @if (booking.Status == "Confirmed")
                                        {
                                            <span class="badge bg-success mt-1">Active</span>
                                        }
                                        else if (booking.Status == "Pending")
                                        {
                                            <span class="badge bg-warning mt-1">Pending</span>
                                        }
                                    </div>
                                    <div class="text-end">
                                        <p class="fw-bold mb-0">R @booking.Amount.ToString("N0")</p>
                                        <small class="text-muted">Total</small>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">No active bookings</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0"><i class="bi bi-receipt text-gold"></i> Recent Invoices</h5>
                        <a href="/Invoice" class="btn btn-sm btn-outline-gold">View All</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.RecentInvoices != null && Model.RecentInvoices.Any())
                    {
                        foreach (var invoice in Model.RecentInvoices)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="mb-1">@invoice.InvoiceNumber</h6>
                                        <p class="text-muted small mb-0">Due: @invoice.DueDate.ToString("dd MMM yyyy")</p>
                                        <span class="badge bg-warning mt-1">Pending</span>
                                    </div>
                                    <div class="text-end">
                                        <p class="fw-bold mb-0 text-gold">R @invoice.Amount.ToString("N0")</p>
                                        <a href="/Invoice/Pay/@invoice.BookingId" class="btn btn-sm btn-success mt-1">Pay</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center py-3">No pending invoices</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <h5 class="mb-3"><i class="bi bi-lightning-charge text-gold"></i> Quick Actions</h5>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <a href="/Reserve" class="btn btn-outline-gold w-100">
                                <i class="bi bi-calendar-plus"></i> New Booking
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Invoice" class="btn btn-outline-gold w-100">
                                <i class="bi bi-credit-card"></i> Pay Invoice
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Customer/DeliverySchedule" class="btn btn-outline-gold w-100">
                                <i class="bi bi-truck"></i> Schedule Delivery
                            </a>
                        </div>
                        <div class="col-md-3">
                            <a href="/Customer/Profile" class="btn btn-outline-gold w-100">
                                <i class="bi bi-person-gear"></i> Update Profile
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .btn-outline-gold {
        color: var(--gold);
        border-color: var(--gold);
    }
    .btn-outline-gold:hover {
        background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
        color: var(--charcoal);
        border-color: transparent;
    }
</style>