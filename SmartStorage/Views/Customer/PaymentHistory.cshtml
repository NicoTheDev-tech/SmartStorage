@model IEnumerable<SmartStorage.Core.DTOs.InvoiceDto>
@{
    ViewData["Title"] = "Payment History";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">Payment History</h1>
        <div class="gold-line mx-auto"></div>
        <p class="text-muted mt-3">Complete payment history</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Invoice #</th>
                                <th>Invoice Date</th>
                                <th>Due Date</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var invoice in Model)
                            {
                                <tr>
                                    <td class="fw-semibold">@invoice.InvoiceNumber</td>
                                    <td>@invoice.InvoiceDate.ToString("dd MMM yyyy")</td>
                                    <td>@invoice.DueDate.ToString("dd MMM yyyy")</td>
                                    <td>R @invoice.Amount.ToString("N2")</td>
                                    <td>
                                        @if (invoice.Status == "Paid")
                                        {
                                            <span class="badge bg-success">Paid</span>
                                        }
                                        else if (invoice.Status == "Cancelled")
                                        {
                                            <span class="badge bg-secondary">Cancelled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="/Invoice/Details/@invoice.Id" class="btn btn-sm btn-outline-gold">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-clock-history fs-1 text-muted"></i>
            <h4 class="text-muted mt-3">No Payment History</h4>
            <p class="text-muted">You haven't made any payments yet.</p>
            <a href="/Invoice" class="btn btn-gold mt-2">View Invoices</a>
        </div>
    }
</div>