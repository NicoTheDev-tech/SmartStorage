@{
    ViewData["Title"] = "Create Admin Account";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg">
                <div class="card-header text-center py-4" style="background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);">
                    <i class="bi bi-shield-lock fs-1 text-white"></i>
                    <h3 class="text-white mb-0 mt-2">Create Admin Account</h3>
                </div>
                <div class="card-body p-5">
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success">
                            <i class="bi bi-check-circle-fill me-2"></i> @ViewBag.Success
                        </div>
                        <div class="text-center mt-3">
                            <a href="/Account/Login" class="btn btn-gold">Login Now</a>
                        </div>
                    }
                    else
                    {
                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                            </div>
                        }

                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control" placeholder="admin@smartstorage.com" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password" name="password" class="form-control" placeholder="********" required />
                                <small class="text-muted">Password must be at least 6 characters</small>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Full Name (Optional)</label>
                                <input type="text" name="fullName" class="form-control" placeholder="Administrator" />
                            </div>
                            <button type="submit" class="btn btn-gold w-100 py-2">Create Admin Account</button>
                        </form>
                        
                        <div class="mt-4 text-center">
                            <p class="text-muted">Note: This page should be secured or removed after initial setup</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .text-gold {
        color: var(--gold);
    }
    .btn-gold {
        background: linear-gradient(135deg, #D4AF37 0%, #B8860B 100%);
        color: #2c2c2c;
        font-weight: 600;
        border: none;
    }
    .btn-gold:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
    }
</style>